NODE_ENV=development
PORT=3000

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=vitahub
DB_PASSWORD=
DB_DATABASE=vitahub
DB_LOGGING=false

# Public URLs and browser access
# Production/iHosting example:
# CORS_ORIGIN=https://reservas.tudominio.cl
# APP_PUBLIC_URL=https://reservas.tudominio.cl
# API_PUBLIC_URL=https://reservas.tudominio.cl/api
CORS_ORIGIN=http://localhost:5173
APP_PUBLIC_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:3000/api
ENABLE_SWAGGER=true
ALLOW_PUBLIC_REGISTRATION=false

# Authentication and encrypted integration credentials
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=10
INTEGRATION_ENCRYPTION_KEY=
OAUTH_STATE_SECRET=

# Private file storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_BYTES=20971520
TRUST_PROXY_HOPS=1

# Cloudinary (optional; enables image uploads for logos/backgrounds)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_MAX_IMAGE_BYTES=5242880

# cPanel email (optional; set true only after creating the mailbox)
SMTP_ENABLED=false
SMTP_HOST=mail.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=notificaciones@example.com
SMTP_PASSWORD=
SMTP_FROM=notificaciones@example.com
SMTP_REPLY_TO=

# Meta
META_APP_ID=
META_APP_SECRET=
META_GRAPH_API_VERSION=v23.0
META_WEBHOOK_VERIFY_TOKEN=
META_TEST_EVENT_CODE=
META_CONVERSIONS_ACCESS_TOKEN=

# Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_DEVELOPER_TOKEN=
GOOGLE_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_API_VERSION=v24

# Optional internal conversation service
CONVERSATION_SERVICE_URL=
INTERNAL_API_TOKEN=
