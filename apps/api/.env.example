NODE_ENV=production
PORT=3000
API_HOST=0.0.0.0

# MySQL - iHosting/cPanel Production
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=vitahub_user
DB_PASSWORD=change_this_to_secure_password
DB_DATABASE=vitahub_prod
DB_LOGGING=false
DATABASE_URL=mysql://vitahub_user:change_this_to_secure_password@localhost:3306/vitahub_prod

# Public URLs and browser access
# Production/iHosting example:
CORS_ORIGIN=https://yourdomain.com
APP_PUBLIC_URL=https://yourdomain.com
API_PUBLIC_URL=https://yourdomain.com/api
ENABLE_SWAGGER=false
ALLOW_PUBLIC_REGISTRATION=false
TRUST_PROXY_HOPS=1

# Authentication and encrypted integration credentials
JWT_SECRET=generate_a_long_random_string_here_minimum_32_characters
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=10
INTEGRATION_ENCRYPTION_KEY=generate_another_random_32_char_string
OAUTH_STATE_SECRET=generate_another_random_string_here

# Private file storage (outside public_html for security)
UPLOAD_DIR=/home/cpanel_username/private_files/uploads
MAX_UPLOAD_BYTES=20971520

# Performance & Monitoring
LOG_LEVEL=info
SENTRY_DSN=your_sentry_dsn_for_production_errors
SENTRY_ENVIRONMENT=production
ENABLE_SLOW_QUERY_LOGGING=true
ENABLE_WEBHOOK_LOGGING=true
ENABLE_AUDIT_TRAIL=true

# Pagination Settings
PAGINATION_DEFAULT_LIMIT=20
PAGINATION_MAX_LIMIT=100

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Cloudinary (optional; enables image uploads for logos/backgrounds)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_MAX_IMAGE_BYTES=5242880

# cPanel Email Configuration
SMTP_ENABLED=true
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=noreply@yourdomain.com
SMTP_PASSWORD=your_cpanel_email_password
SMTP_FROM=noreply@yourdomain.com
SMTP_REPLY_TO=support@yourdomain.com

# Meta API Integration
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_GRAPH_API_VERSION=v23.0
META_WEBHOOK_VERIFY_TOKEN=generate_a_random_token_here
META_TEST_EVENT_CODE=
META_CONVERSIONS_ACCESS_TOKEN=your_meta_conversions_token

# Google Integration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_DEVELOPER_TOKEN=your_google_developer_token
GOOGLE_LOGIN_CUSTOMER_ID=your_google_customer_id
GOOGLE_ADS_API_VERSION=v24

# Redis (Optional - recommended for production caching)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Optional internal conversation service
CONVERSATION_SERVICE_URL=
INTERNAL_API_TOKEN=

# Security Headers
HELMET_ENABLED=true
CSP_ENABLED=true
HSTS_ENABLED=true
